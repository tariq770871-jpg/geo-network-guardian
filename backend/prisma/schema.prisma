datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  roleId       String   @map("role_id")
  role         Role     @relation(fields: [roleId], references: [id])
  mfaEnabled   Boolean  @default(false) @map("mfa_enabled")
  mfaSecret    String?  @map("mfa_secret")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userPermissions UserPermission[]

  @@map("users")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(200)
  description String?  @db.Text
  module      String   @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model Role {
  id           String    @id @default(uuid())
  name         String    @unique @db.VarChar(50)
  parentRoleId String?   @map("parent_role_id")
  parentRole   Role?     @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles   Role[]    @relation("RoleHierarchy")
  version      Int       @default(1)
  isSystem     Boolean   @default(false) @map("is_system")
  isEditable   Boolean   @default(true) @map("is_editable")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)
  assignedAt   DateTime   @default(now()) @map("assigned_at")

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  userId       String           @map("user_id")
  permissionId String           @map("permission_id")
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Restrict)
  effect       PermissionEffect @default(Allow)
  assignedAt   DateTime         @default(now()) @map("assigned_at")

  @@id([userId, permissionId])
  @@map("user_permissions")
}

enum PermissionEffect {
  Allow
  Deny
}

model RbacAuditLog {
  id          String   @id @default(uuid())
  actorUserId String   @map("actor_user_id")
  targetType  String   @map("target_type") @db.VarChar(50)
  targetId    String   @map("target_id")
  action      String   @db.VarChar(50)
  changes     Json     @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("rbac_audit_logs")
}
